# ─── Load models ──────────────────────────────────────────────────────────────

def load_models(config):
    """Load FLUX schnell + ControlNet"""
    device = config["device"]

    print("Loading depth estimator...")
    depth_estimator = hf_pipeline(
        "depth-estimation",
        model="depth-anything/Depth-Anything-V2-Small-hf",
        device=0 if device == "cuda" else -1,
    )

    print("Loading ControlNet Union Pro 2.0...")
    controlnet_union = FluxControlNetModel.from_pretrained(
        "Shakker-Labs/FLUX.1-dev-ControlNet-Union-Pro-2.0",
        torch_dtype=torch.bfloat16,
    )
    controlnet = FluxMultiControlNetModel([controlnet_union])

    print("Loading FLUX schnell pipeline...")
    pipe = FluxControlNetPipeline.from_pretrained(
        "black-forest-labs/FLUX.1-schnell",
        controlnet=controlnet,
        torch_dtype=torch.bfloat16,
    )
    pipe.enable_model_cpu_offload()
    pipe.enable_attention_slicing()

    return depth_estimator, pipe




# ─── Control images ───────────────────────────────────────────────────────────

def get_depth_map(image, depth_estimator):
    depth = depth_estimator(image)["depth"]
    return depth.convert("RGB").resize(image.size)


def get_canny_edges(image):
    img_array = np.array(image.convert("RGB"))
    gray      = cv2.cvtColor(img_array, cv2.COLOR_RGB2GRAY)
    edges     = cv2.Canny(gray, 100, 200)
    return Image.fromarray(cv2.cvtColor(edges, cv2.COLOR_GRAY2RGB))


# ─── Main pipeline ────────────────────────────────────────────────────────────

def redesign_room(config=CONFIG):
    device       = config["device"]
    image_path   = config["image_path"]
    room_type    = config["room_type"]
    style        = config["style"]
    extra_prompt = config["extra_prompt"]

    if room_type not in STYLES:
        raise ValueError(f"Unknown room_type '{room_type}'. Choose from: {list(STYLES.keys())}")
    if style not in STYLES[room_type]:
        raise ValueError(f"Unknown style '{style}' for '{room_type}'. Choose from: {list(STYLES[room_type].keys())}")

    if config.get("hf_token"):
        from huggingface_hub import login
        login(token=config["hf_token"])

    image = load_image(image_path).convert("RGB").resize((768, 768), Image.LANCZOS)

    style_config    = STYLES[room_type][style]
    prompt          = style_config["prompt"]
    if extra_prompt:
        prompt = prompt + " " + extra_prompt + "."
    negative_prompt = style_config["negative_prompt"]

    print(f"Room: {room_type} | Style: {style}")

    # All styles use the same ControlNet pipeline
    depth_estimator, pipe = load_models(config)

    print("Generating depth map...")
    depth_image = get_depth_map(image, depth_estimator)
    depth_image.save("depth_map.png")

    print("Generating canny edges...")
    canny_image = get_canny_edges(image)
    canny_image.save("canny_edges.png")

    print("Generating image with FLUX...")
    result = pipe(
        prompt=prompt,
        control_image=[depth_image, canny_image],
        control_mode=[2, 0],
        controlnet_conditioning_scale=[config["depth_scale"], config["canny_scale"]],
        control_guidance_end=config["control_guidance_end"],
        num_inference_steps=config["num_inference_steps"],
        guidance_scale=config["guidance_scale"],
        height=768,
        width=768,
    ).images[0]

    result.save("output_best.png")

    comparison = Image.new("RGB", (image.width * 2 + 20, image.height), (20, 20, 20))
    comparison.paste(image, (0, 0))
    comparison.paste(result.resize((image.width, image.height)), (image.width + 20, 0))
    comparison.save("comparison.png")

    print("Done. Saved: output_best.png, comparison.png")
    return result


